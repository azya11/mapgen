# Copy to .env (or set in your shell) to enable the Claude parser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides:
# MAPGEN_MODEL=claude-sonnet-4-6
# MAPGEN_PARSER=auto        # auto | claude | rule
# MAPGEN_OFFLINE=0          # 1 to force fully offline
# MAPGEN_RESOLUTION=96
# MAPGEN_SEED=1234

# ---------------------------------------------------------------------------
# Web app — local single-host mode (SQLite + in-process generation).
# Leave WORKER_URL unset and the app runs the pipeline itself.
# WEB_SECRET_KEY=change-me-to-a-random-48-char-string
# WEB_COOKIE_SECURE=0       # 1 in production (HTTPS) — enables Secure cookies + HSTS
# WEB_TRUST_PROXY=0         # 1 behind a reverse proxy / Vercel

# ---------------------------------------------------------------------------
# Split deployment (free Vercel + free worker). See DEPLOY.md.
#
# On the Vercel app:
# DATABASE_URL=postgresql://user:pass@host/db   # Neon/Supabase; SQLite won't persist
# WORKER_URL=https://your-worker.hf.space        # the deployed worker
# WORKER_SECRET=shared-random-secret             # MUST match the worker
#
# On the worker (Hugging Face Space / Render / Fly / Cloud Run):
# WORKER_SECRET=shared-random-secret             # MUST match Vercel
# ALLOWED_ORIGINS=https://your-app.vercel.app    # browser origin(s) for CORS
# ANTHROPIC_API_KEY=sk-ant-...                   # optional, Claude parser
